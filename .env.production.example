# Example production environment for the frontend
# Copy this file to .env.production (or set these values in Vercel) and fill in real values.

# Public API URL served by your backend (must be HTTPS in production)
NEXT_PUBLIC_API_URL=https://verilearn-backend.vercel.app
NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_URL}

# Agora (for real-time video/audio). Leave empty if not using Agora.
NEXT_PUBLIC_AGORA_APP_ID=your-agora-app-id

# Vite/legacy variables (if parts of the app use VITE_ prefixed vars)
VITE_API_BASE_URL=${NEXT_PUBLIC_API_URL}

# Supabase (public/publishable keys only) — set if you use Supabase services
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_project_publishable_key

# Notes:
# - Do NOT put sensitive server-side secrets (DB URIs, JWT secrets) in the frontend
#   project — they must live in the backend Vercel project as server-side environment variables.
# - In Vercel add these as Environment Variables under Project → Settings → Environment Variables.